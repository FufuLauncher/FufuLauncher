<Window
    x:Class="FufuLauncher.Views.DownloadWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Title="{helpers:Loc Key=DownloadWindow_Title}">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="40" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="8">
                <TextBlock Text="{helpers:Loc Key=DownloadWindow_Title}" VerticalAlignment="Center" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="32,12,32,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <RowDefinition Height="Auto" /> <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{helpers:Loc Key=DownloadWindow_GameResourceUpdate}" FontWeight="Bold" FontSize="28" />
                <TextBlock Text="{helpers:Loc Key=DownloadWindow_StuckIsNormal}" Opacity="0.6" FontSize="14" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,24" ColumnSpacing="16" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox x:Name="PathBox" Grid.Row="0" Grid.Column="0" Header="{helpers:Loc Key=DownloadWindow_InstallDir}" IsReadOnly="True" />
                <ComboBox x:Name="LanguageCombo" Grid.Row="0" Grid.Column="1" Header="{helpers:Loc Key=DownloadWindow_VoiceLanguage}" SelectedIndex="0"
                          HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="简体中文 (zh-cn)" Tag="zh-cn" />
                    <ComboBoxItem Content="English (en-us)" Tag="en-us" />
                    <ComboBoxItem Content="日本語 (ja-jp)" Tag="ja-jp" />
                    <ComboBoxItem Content="한국어 (ko-kr)" Tag="ko-kr" />
                </ComboBox>

                <CheckBox x:Name="BaseGameCheck" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                          IsChecked="True" Content="{helpers:Loc Key=DownloadWindow_DownloadBaseGame}"
                          ToolTipService.ToolTip="{helpers:Loc Key=DownloadWindow_BaseGameTooltip}" />
            </Grid>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ToggleButton x:Name="LogToggle" Content="{helpers:Loc Key=DownloadWindow_ShowDetailLog}" Click="LogToggle_Click" Height="32" Margin="0,0,0,8" />
                <Border x:Name="LogBorder" Grid.Row="1" Visibility="Collapsed"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <ScrollViewer x:Name="LogScroller" Padding="8">
                        <TextBlock x:Name="LogBlock" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3" Spacing="8">
                <Grid>
                    <TextBlock x:Name="StatusText" Text="{helpers:Loc Key=DownloadWindow_Ready}" FontWeight="SemiBold" />
                    <TextBlock x:Name="ProgressText" Text="0%" HorizontalAlignment="Right" Opacity="0.7" />
                </Grid>
                <ProgressBar x:Name="MainProgressBar" Maximum="100" Height="8" CornerRadius="4" />
                <Grid Margin="0,16,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                        <Button x:Name="StartButton" Content="{helpers:Loc Key=DownloadWindow_StartDownload}" Click="StartButton_Click" Width="120" Height="36" />
                        <Button x:Name="CancelButton" Content="{helpers:Loc Key=DownloadWindow_Cancel}" Click="CancelButton_Click" IsEnabled="False"
                                Width="100" Height="36" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>