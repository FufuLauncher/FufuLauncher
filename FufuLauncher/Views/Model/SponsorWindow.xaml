<Window
    x:Class="FufuLauncher.Views.SponsorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:FufuLauncher.Helpers"
    Title="{helpers:Loc Key=SponsorWindow_Title}">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="32" Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{helpers:Loc Key=SponsorWindow_Title}"
                   FontFamily="{StaticResource AppGlobalFont}"
                   Style="{ThemeResource TitleTextBlockStyle}"
                   Grid.Row="0"
                   Margin="0,0,0,16" />

        <TextBlock Text="{helpers:Loc Key=SponsorWindow_OnlyWeChat}"
                   FontFamily="{StaticResource AppGlobalFont}"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                   Grid.Row="1"
                   Margin="0,0,0,16" />

        <Border Grid.Row="2"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,0,0,24">
            <Image x:Name="QrCodeImage"
                   Stretch="Uniform"
                   Opacity="0">
                <Image.Resources>
                    <Storyboard x:Name="FadeInStoryboard">
                        <DoubleAnimation Storyboard.TargetName="QrCodeImage"
                                         Storyboard.TargetProperty="Opacity"
                                         From="0" To="1" Duration="0:0:0.6">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut" />
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </Image.Resources>
            </Image>
        </Border>

        <TextBlock x:Name="ErrorText"
                   Grid.Row="2"
                   Text="{helpers:Loc Key=SponsorWindow_QrCodeFailed}"
                   FontFamily="{StaticResource AppGlobalFont}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   Visibility="Collapsed" />

        <TextBlock Text="{helpers:Loc Key=SponsorWindow_Disclaimer}"
                   FontFamily="{StaticResource AppGlobalFont}"
                   Style="{ThemeResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Grid.Row="3" />
    </Grid>
</Window>