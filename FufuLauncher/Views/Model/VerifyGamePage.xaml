<Page
    x:Class="FufuLauncher.Views.VerifyGamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:FufuLauncher.Helpers"
    Background="Transparent">

    <Grid Padding="32">
        <StackPanel VerticalAlignment="Center" Spacing="24">
            <FontIcon Glyph="&#xE9F5;" FontSize="48" Opacity="0.8" />
            <TextBlock Text="{helpers:Loc Key=VerifyGame_Title}" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="{helpers:Loc Key=VerifyGame_Description}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" Opacity="0.6" TextAlignment="Center"
                       MaxWidth="400" />
            <Button x:Name="StartVerifyBtn" Content="{helpers:Loc Key=VerifyGame_Start}" Click="StartVerifyBtn_Click"
                    HorizontalAlignment="Center" MinWidth="160" Height="40" />
        </StackPanel>
    </Grid>
</Page>