<Window
    x:Class="FufuLauncher.Views.AchievementWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FufuLauncher.Models"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Title="{helpers:Loc Key=AchievementWindow_Title}">
    
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    
    <Grid>
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="AppBackground" Color="#FFF3F3F3"/>
                        <SolidColorBrush x:Key="SidebarBackground" Color="#FFF9F9F9"/>
                        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF"/>
                        <SolidColorBrush x:Key="CardBorder" Color="#FFE5E5E5"/>
                        <SolidColorBrush x:Key="HighlightColor" Color="#FF000000"/>
                        <SolidColorBrush x:Key="SubTextColor" Color="#FF666666"/>
                        <SolidColorBrush x:Key="ImageBackgroundBrush" Color="#0D000000"/>
                        <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#1A000000"/>
                        <SolidColorBrush x:Key="SeparatorBrush" Color="#1A000000"/>
                    </ResourceDictionary>
                    
                    <ResourceDictionary x:Key="Default">
                        <SolidColorBrush x:Key="AppBackground" Color="#FF1E1E1E"/>
                        <SolidColorBrush x:Key="SidebarBackground" Color="#FF252526"/>
                        <SolidColorBrush x:Key="CardBackground" Color="#FF2D2D30"/>
                        <SolidColorBrush x:Key="CardBorder" Color="#FF3E3E42"/>
                        <SolidColorBrush x:Key="HighlightColor" Color="#FFECECEC"/>
                        <SolidColorBrush x:Key="SubTextColor" Color="#FFAAAAAA"/>
                        <SolidColorBrush x:Key="ImageBackgroundBrush" Color="#33000000"/>
                        <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#33FFFFFF"/>
                        <SolidColorBrush x:Key="SeparatorBrush" Color="#33FFFFFF"/>
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <Style x:Key="ToolbarButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Foreground" Value="{ThemeResource HighlightColor}"/>
                    <Setter Property="Padding" Value="8"/>
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>

                <DataTemplate x:Key="AchievementCardTemplate" x:DataType="models:AchievementItem">
                    <Grid Background="{ThemeResource CardBackground}" CornerRadius="6" Padding="12" Opacity="{x:Bind Opacity, Mode=OneWay}" 
                          BorderBrush="{ThemeResource CardBorder}" BorderThickness="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Source="{x:Bind SafeItemIconUrl}" Width="48" Height="48" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <Border Grid.Column="1" Background="{ThemeResource ImageBackgroundBrush}" CornerRadius="4" Padding="8" VerticalAlignment="Top" Margin="0,0,16,0">
                            <StackPanel>
                                <Image Source="{x:Bind SafePrimogemUrl}" Width="20" Height="20" Margin="0,0,0,4"/>
                                <TextBlock Text="{x:Bind RewardCount}" Foreground="{ThemeResource HighlightColor}" HorizontalAlignment="Center" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{x:Bind Title}" Foreground="{ThemeResource HighlightColor}" FontWeight="Bold" FontSize="14"/>
                                <Border Background="#33FFFF00" CornerRadius="2" Padding="4,0" VerticalAlignment="Center" Visibility="{x:Bind ProgressVisibility, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind ProgressText, Mode=OneWay}" FontSize="10" Foreground="#FFFFCC00"/>
                                </Border>
                                <Border Background="{ThemeResource BadgeBackgroundBrush}" CornerRadius="2" Padding="4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Version}" FontSize="10" Foreground="{ThemeResource SubTextColor}"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{x:Bind Description}" Foreground="{ThemeResource SubTextColor}" FontSize="12" TextWrapping="Wrap" Margin="0,0,8,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind CompletionTimeVisibility, Mode=OneWay}">
                                <FontIcon Glyph="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="{ThemeResource SubTextColor}"/>
                                <TextBlock Text="{x:Bind CompletionTimeText, Mode=OneWay}" Foreground="{ThemeResource SubTextColor}" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Content="{helpers:Loc Key=AchievementWindow_ViewGuide}" 
                                    FontSize="12" 
                                    Padding="8,4"
                                    Click="OnSearchGuideClick"
                                    ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_SearchGuideTooltip}"/>
                            
                            <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ResourceDictionary>
        </Grid.Resources>

        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="AppTitleBar" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Image Source="/Assets/WindowIcon.ico" Width="16" Height="16" Margin="0,0,12,0" />
                    <TextBlock Text="{helpers:Loc Key=AchievementWindow_Archive}" FontSize="12" Foreground="{ThemeResource SubTextColor}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Padding="16,0" BorderBrush="{ThemeResource CardBorder}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> 
                    <ColumnDefinition Width="*"/>    
                    <ColumnDefinition Width="Auto"/> 
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <Button Content="{x:Bind ViewModel.ViewToggleIcon, Mode=OneWay}" 
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" 
                            Click="OnToggleViewMode" 
                            Style="{StaticResource ToolbarButtonStyle}" 
                            FontSize="16" 
                            ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_SwitchView}"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        
                        <StackPanel Orientation="Horizontal" Spacing="6" ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_PrimogemTooltip}">
                            <Image Source="/Assets/Primogem.png" Width="18" Height="18" VerticalAlignment="Center"/> 
                            <TextBlock Text="{x:Bind ViewModel.PrimogemStatText, Mode=OneWay}" Foreground="{ThemeResource HighlightColor}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Rectangle Width="1" Height="16" Fill="{ThemeResource SeparatorBrush}" VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" Spacing="6" ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_ProgressTooltip}">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="{ThemeResource SubTextColor}" VerticalAlignment="Center" FontSize="14"/>
                            <TextBlock Text="{x:Bind ViewModel.ProgressStatText, Mode=OneWay}" Foreground="{ThemeResource SubTextColor}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                    </StackPanel>
                </StackPanel>

                <AutoSuggestBox Grid.Column="1" PlaceholderText="{helpers:Loc Key=AchievementWindow_SearchPlaceholder}" Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" QueryIcon="Find" Margin="20,0" VerticalAlignment="Center" MaxWidth="400"/>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ComboBox ItemsSource="{x:Bind ViewModel.AvailableVersions}" SelectedItem="{x:Bind ViewModel.SelectedVersion, Mode=TwoWay}" PlaceholderText="{helpers:Loc Key=AchievementWindow_Version}" MinWidth="100" VerticalAlignment="Center"/>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.HideCompleted, Mode=TwoWay}" OnContent="{helpers:Loc Key=AchievementWindow_HiddenComplete}" OffContent="{helpers:Loc Key=AchievementWindow_ShowAll}" VerticalAlignment="Center" MinWidth="100"/>
                    
                    <Button Click="OnUiafImportClick" VerticalAlignment="Center" Padding="8,5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE118;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                            <TextBlock Text="{helpers:Loc Key=AchievementWindow_UIAFImport}" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Click="OnUiafExportClick" VerticalAlignment="Center" Padding="8,5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE11C;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                            <TextBlock Text="{helpers:Loc Key=AchievementWindow_UIAFExport}" FontSize="12"/>
                        </StackPanel>
                    </Button>

                    <Button Content="{helpers:Loc Key=AchievementWindow_ImportRecords}" Click="OnImportClick" FontSize="12" VerticalAlignment="Center"/>

                    <Button Click="OnExportClick" VerticalAlignment="Center" Padding="8,5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74E;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                            <TextBlock Text="{helpers:Loc Key=AchievementWindow_ManualSave}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Border Background="{ThemeResource BadgeBackgroundBrush}" CornerRadius="4" Padding="8,4" Margin="0,0,8,0" VerticalAlignment="Center" ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_CurrentProfile}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE779;" FontFamily="Segoe Fluent Icons" FontSize="12" Foreground="{ThemeResource SubTextColor}"/>
                            <TextBlock Text="{x:Bind CurrentProfileName, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource HighlightColor}" MaxWidth="100" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <Button Click="OnArchiveManageClick" VerticalAlignment="Center" Padding="8,5" Margin="0,0,8,0" ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_ManageArchive}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE71C;" FontFamily="Segoe Fluent Icons" FontSize="14"/>
                            <TextBlock Text="{helpers:Loc Key=AchievementWindow_ArchiveManagement}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Click="OnUpdateDbClick" ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_UpdateData}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14"/>
                            <TextBlock Text="{helpers:Loc Key=AchievementWindow_UpdateData}" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <GridView x:Name="CategoryGridView"
                          Visibility="{x:Bind ViewModel.CategoryGridVisibility, Mode=OneWay}"
                          ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                          SelectionMode="None" IsItemClickEnabled="True" ItemClick="OnCategoryGridItemClick" Padding="20">
                    <GridView.RenderTransform>
                        <TranslateTransform x:Name="GridTrans" Y="0"/>
                    </GridView.RenderTransform>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:AchievementCategory">
                            <Grid Width="200" Height="140" Background="{ThemeResource CardBackground}" CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardBorder}" BorderThickness="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Image Source="{x:Bind SafeIconUrl}" Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Text="{x:Bind Name}" Foreground="{ThemeResource HighlightColor}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
                                <StackPanel Grid.Row="2" Spacing="4">
                                    <ProgressBar Value="{x:Bind ProgressPercent, Mode=OneWay}" Maximum="100" Height="2"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                        <TextBlock Text="{x:Bind ProgressDisplay, Mode=OneWay}" FontSize="10" Foreground="{ThemeResource SubTextColor}"/>
                                        <TextBlock Text="{x:Bind ProgressPercentText, Mode=OneWay}" FontSize="10" Foreground="{ThemeResource SubTextColor}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <Grid x:Name="DetailView" Visibility="{x:Bind ViewModel.DetailListVisibility, Mode=OneWay}">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="DetailTrans" Y="0"/>
                    </Grid.RenderTransform>
                    
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListView Grid.Column="0" 
                              ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                              SelectionChanged="OnCategorySelectionChanged"
                              Background="{ThemeResource SidebarBackground}" Padding="0,10">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AchievementCategory">
                                <Grid Padding="8,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{x:Bind SafeIconUrl}" Width="32" Height="32" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" Foreground="{ThemeResource HighlightColor}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind ProgressDisplay, Mode=OneWay}" Foreground="{ThemeResource SubTextColor}" FontSize="11"/>
                                            <TextBlock Text="{x:Bind ProgressPercentText, Mode=OneWay}" Foreground="{ThemeResource SubTextColor}" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ListView Grid.Column="1" 
                              ItemsSource="{x:Bind ViewModel.FilteredAchievements, Mode=OneWay}"
                              SelectionMode="None" Padding="20">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,8"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AchievementItem">
                                <Grid>
                                    <ContentControl 
                                        Content="{x:Bind}" 
                                        ContentTemplate="{StaticResource AchievementCardTemplate}"
                                        Visibility="{x:Bind SingleItemVisibility, Mode=OneWay}"
                                        HorizontalContentAlignment="Stretch"/>

                                    <Expander 
                                        Visibility="{x:Bind GroupVisibility, Mode=OneWay}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="{ThemeResource CardBackground}"
                                        BorderBrush="{ThemeResource CardBorder}"
                                        CornerRadius="6"
                                        IsExpanded="True">
                                        
                                        <Expander.Header>
                                            <Grid HorizontalAlignment="Stretch" Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Image Source="{x:Bind SafeItemIconUrl}" Width="32" Height="32" Margin="0,0,12,0"/>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Description}" Foreground="{ThemeResource SubTextColor}" FontSize="13" TextWrapping="Wrap"/>
        
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                                        <TextBlock FontSize="10" Foreground="#FFFFCC00" Visibility="{x:Bind ProgressVisibility, Mode=OneWay}">
                                                            <Run Text="{helpers:Loc Key=AchievementWindow_Progress}"/><Run Text="{x:Bind ProgressText, Mode=OneWay}"/>
                                                        </TextBlock>
            
                                                        <TextBlock FontSize="10" Foreground="{ThemeResource SubTextColor}">
                                                            <Run Text="v"/><Run Text="{x:Bind Version}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{x:Bind GroupProgressText, Mode=OneWay}" 
                                                           VerticalAlignment="Center" Foreground="{ThemeResource SubTextColor}" FontSize="12" Margin="0,0,16,0"/>
                                            </Grid>
                                        </Expander.Header>

                                         <ItemsControl ItemsSource="{x:Bind Children, Mode=OneWay}" Margin="-12,0,-12,-12">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="models:AchievementItem">
                                                    <Grid Background="{ThemeResource SidebarBackground}" Padding="12,8" BorderBrush="{ThemeResource SeparatorBrush}" BorderThickness="0,1,0,0" Opacity="{x:Bind Opacity, Mode=OneWay}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/> 
                                                            <ColumnDefinition Width="*"/>    
                                                            <ColumnDefinition Width="Auto"/> 
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" Background="{ThemeResource ImageBackgroundBrush}" CornerRadius="4" Padding="6,4" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="40">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                                                <Image Source="{x:Bind SafePrimogemUrl}" Width="16" Height="16"/>
                                                                <TextBlock Text="{x:Bind RewardCount}" Foreground="{ThemeResource HighlightColor}" FontSize="12" FontWeight="Bold"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Title}" Foreground="{ThemeResource HighlightColor}" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                                            <TextBlock Text="{x:Bind Description}" Foreground="{ThemeResource SubTextColor}" FontSize="13" TextWrapping="Wrap"/>
                                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                                                <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind CompletionTimeVisibility, Mode=OneWay}">
                                                                    <FontIcon Glyph="&#xE823;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="{ThemeResource SubTextColor}"/>
                                                                    <TextBlock Text="{x:Bind CompletionTimeText, Mode=OneWay}" Foreground="{ThemeResource SubTextColor}" FontSize="11"/>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                            <Button Content="{helpers:Loc Key=AchievementWindow_ViewGuide}" 
                                                                    FontSize="11" 
                                                                    Padding="6,3"
                                                                    Click="OnSearchGuideClick"
                                                                    ToolTipService.ToolTip="{helpers:Loc Key=AchievementWindow_SearchGuideTooltip}"/>

                                                            <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>