<Window
    x:Class="FufuLauncher.Views.AchievementUpdaterWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Title="{helpers:Loc Key=AchievementUpdater_Title}">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock Text="{helpers:Loc Key=AchievementUpdater_Title}" Style="{ThemeResource TitleTextBlockStyle}" HorizontalAlignment="Center" />

            <Button x:Name="StartButton"
                    Content="{helpers:Loc Key=AchievementUpdater_StartFetch}"
                    Click="OnStartClick"
                    HorizontalAlignment="Center"
                    Padding="32,8" />
        </StackPanel>
    </Grid>
</Window>