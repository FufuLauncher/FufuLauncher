<Window
    x:Class="FufuLauncher.Views.PreDownloadWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="32,48,32,32">
        <StackPanel VerticalAlignment="Center" Spacing="24">
            <FontIcon Glyph="&#xE896;" FontSize="48" Opacity="0.8"/>
            <TextBlock Text="游戏预下载" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="提前获取新版本更新数据，过程自动" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
            <Button x:Name="StartBtn" Content="开始预下载" Width="200" Height="40" HorizontalAlignment="Center" Click="StartBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>