<?xml version="1.0" encoding="utf-8"?>

<ContentDialog
    x:Class="FufuLauncher.Views.GenshinHDRLuminanceSettingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:FufuLauncher.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:DefaultBindMode="OneWay"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    BorderThickness="1"
    BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
    Style="{ThemeResource DefaultContentDialogStyle}"
    PrimaryButtonText="{helpers:Loc Key=HDR_SaveAndApply}"
    PrimaryButtonCommand="{x:Bind SaveCommand}"
    CloseButtonText="{helpers:Loc Key=CancelBtn}"
    CloseButtonCommand="{x:Bind CloseCommand}"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">600</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">800</x:Double>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </ContentDialog.Resources>

    <Grid Width="500" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{helpers:Loc Key=HDR_BrightnessConfig}" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20" />

        <StackPanel Grid.Row="1" Spacing="8" Margin="0,0,0,12">
            <InfoBar IsOpen="{x:Bind HDRNotSupported}" Severity="Warning" Title="{helpers:Loc Key=HDR_NotSupported}" Message="{helpers:Loc Key=HDR_NotSupportedMsg}"
                     IsClosable="False" />
            <InfoBar IsOpen="{x:Bind HDRNotEnabled}" Severity="Informational" Title="{helpers:Loc Key=HDR_NotEnabled}"
                     Message="{helpers:Loc Key=HDR_NotEnabledMsg}" IsClosable="False" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="{helpers:Loc Key=HDR_DisplayInfo}" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
                    <TextBlock Text="{x:Bind DisplayInfomation}" Style="{ThemeResource CaptionTextBlockStyle}"
                               TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
            <StackPanel Spacing="24" Padding="0,8">
                <StackPanel>
                    <TextBlock Text="{helpers:Loc Key=HDR_SwitchSetting}" Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Margin="0,0,0,8" />
                    <ToggleSwitch IsOn="{x:Bind IsGenshinHDRForceEnabled, Mode=TwoWay}"
                                  OffContent="{helpers:Loc Key=HDR_OffContent}"
                                  OnContent="{helpers:Loc Key=HDR_OnContent}" />
                    <TextBlock Text="{helpers:Loc Key=HDR_RegistryNote}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,4,0,0" />
                </StackPanel>

                <MenuFlyoutSeparator />

                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{helpers:Loc Key=HDR_MaxLuminance}" VerticalAlignment="Center" />
                        <NumberBox HorizontalAlignment="Right" Width="100" Value="{x:Bind MaxLuminance, Mode=TwoWay}"
                                   Minimum="300" Maximum="2000" SpinButtonPlacementMode="Compact" />
                    </Grid>
                    <Slider Value="{x:Bind MaxLuminance, Mode=TwoWay}" Minimum="300" Maximum="2000" />
                </StackPanel>

                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{helpers:Loc Key=HDR_SceneLuminance}" VerticalAlignment="Center" />
                        <NumberBox HorizontalAlignment="Right" Width="100" Value="{x:Bind SceneLuminance, Mode=TwoWay}"
                                   Minimum="100" Maximum="500" SpinButtonPlacementMode="Compact" />
                    </Grid>
                    <Slider Value="{x:Bind SceneLuminance, Mode=TwoWay}" Minimum="100" Maximum="500" />
                </StackPanel>

                <StackPanel>
                    <Grid Margin="0,0,0,4">
                        <TextBlock Text="{helpers:Loc Key=HDR_UILuminance}" VerticalAlignment="Center" />
                        <NumberBox HorizontalAlignment="Right" Width="100" Value="{x:Bind UILuminance, Mode=TwoWay}"
                                   Minimum="150" Maximum="550" SpinButtonPlacementMode="Compact" />
                    </Grid>
                    <Slider Value="{x:Bind UILuminance, Mode=TwoWay}" Minimum="150" Maximum="550" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="3" ColumnSpacing="8" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{helpers:Loc Key=HDR_ResetDefault}" Command="{x:Bind ResetCommand}" HorizontalAlignment="Stretch" />
            <Button Grid.Column="1" Content="{helpers:Loc Key=HDR_AutoAdjust}" Command="{x:Bind AutoAdjustCommand}" HorizontalAlignment="Stretch"
                    ToolTipService.ToolTip="{helpers:Loc Key=HDR_AutoAdjustTooltip}" />
        </Grid>
    </Grid>
</ContentDialog>