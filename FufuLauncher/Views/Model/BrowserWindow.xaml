<Window
    x:Class="FufuLauncher.Views.BrowserWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:helpers="using:FufuLauncher.Helpers"
    mc:Ignorable="d"
    Title="{helpers:Loc Key=BrowserWindow_Title}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Height="40" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center" Margin="16,0,0,0"
                        Spacing="12">
                <Image Source="/Assets/WindowIcon.ico" Width="16" Height="16" />
                <TextBlock Text="{helpers:Loc Key=BrowserWindow_Title}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
            </StackPanel>

            <TextBox x:Name="UrlTextBox" Grid.Column="1" Margin="16,4"
                     PlaceholderText="{helpers:Loc Key=BrowserWindow_EnterUrl}"
                     KeyDown="UrlTextBox_KeyDown"
                     VerticalAlignment="Center" />

            <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="0,0,140,0" Spacing="8">
                <Button Click="Refresh_Click" Padding="8,4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="{helpers:Loc Key=BrowserWindow_Refresh}">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" />
                </Button>

                <Button Click="Settings_Click" Padding="8,4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="{helpers:Loc Key=BrowserWindow_Settings}">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>

                <ToggleButton x:Name="PinButton" Click="PinButton_Click" ToolTipService.ToolTip="{helpers:Loc Key=BrowserWindow_PinWindow}">
                    <FontIcon Glyph="&#xE840;" FontSize="14" />
                </ToggleButton>
            </StackPanel>
        </Grid>

        <WebView2 x:Name="WebView" Grid.Row="1" />

        <ProgressBar x:Name="LoadingBar" Grid.Row="1" VerticalAlignment="Top"
                     IsIndeterminate="True" Visibility="Collapsed"
                     Foreground="{ThemeResource SystemControlForegroundAccentBrush}" />

        <ContentDialog x:Name="SettingsDialog" Title="{helpers:Loc Key=BrowserWindow_SettingsTitle}"
                       PrimaryButtonText="{helpers:Loc Key=SaveBtn}" CloseButtonText="{helpers:Loc Key=CancelBtn}"
                       DefaultButton="Primary" Grid.RowSpan="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" Width="350" Margin="0,0,12,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{helpers:Loc Key=BrowserWindow_DefaultHomepage}" FontWeight="SemiBold" />
                        <TextBox x:Name="SettingUrlBox" PlaceholderText="https://..." />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{helpers:Loc Key=BrowserWindow_DefaultZoom}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Slider x:Name="SettingZoomSlider" Minimum="0.5" Maximum="3.0" StepFrequency="0.1"
                                    Width="250" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ElementName=SettingZoomSlider, Path=Value}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{helpers:Loc Key=BrowserWindow_VideoHotkeys}" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,10,*">
                            <TextBox x:Name="SettingRewindBox" Header="{helpers:Loc Key=BrowserWindow_RewindKey}" PlaceholderText="ArrowLeft" Grid.Column="0" />
                            <TextBox x:Name="SettingForwardBox" Header="{helpers:Loc Key=BrowserWindow_ForwardKey}" PlaceholderText="ArrowRight"
                                     Grid.Column="2" />
                        </Grid>
                        <TextBlock Text="{helpers:Loc Key=BrowserWindow_HotkeyHint}" FontSize="12" Foreground="Gray"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="{helpers:Loc Key=BrowserWindow_PerformanceSettings}" FontWeight="SemiBold" />
                        <ToggleSwitch x:Name="SettingHighPriorityToggle" Header="{helpers:Loc Key=BrowserWindow_RaisePriority}" />
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </ContentDialog>

    </Grid>
</Window>