<Page
    x:Class="FufuLauncher.Views.AdvancedServerSwitchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:FufuLauncher.Helpers"
    Background="Transparent">

    <Grid Padding="32,48,32,32">
        <StackPanel VerticalAlignment="Center" Spacing="24">
            <FontIcon Glyph="&#xE8AB;" FontSize="48" Opacity="0.8" />
            <TextBlock Text="{helpers:Loc Key=AdvancedServerSwitch_Title}" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="{helpers:Loc Key=AdvancedServerSwitch_Warning}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
            <Button x:Name="StartBtn" Content="{helpers:Loc Key=AdvancedServerSwitch_Convert}" Width="200" Height="40" HorizontalAlignment="Center"
                    Click="StartBtn_Click" />
        </StackPanel>
    </Grid>
</Page>