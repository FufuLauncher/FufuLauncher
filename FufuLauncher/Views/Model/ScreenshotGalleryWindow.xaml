<Window
    x:Class="FufuLauncher.Views.ScreenshotGalleryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FufuLauncher.Models"
    mc:Ignorable="d"
    Title="截图图库">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" x:Name="AppTitleBarRow" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.Resources>
            <CollectionViewSource x:Name="GalleryViewSource" IsSourceGrouped="True" ItemsPath="Items" />
        </Grid.Resources>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0" Spacing="8">
                <Image Source="/Assets/WindowIcon.ico" Width="16" Height="16"/>
                <TextBlock Text="截图图库" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <GridView x:Name="GalleryGridView" 
                  Grid.Row="1"
                  ItemsSource="{Binding Source={StaticResource GalleryViewSource}}"
                  Visibility="Collapsed"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="GalleryGridView_ItemClick"
                  Padding="24">

            <GridView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <Style TargetType="GridViewHeaderItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="GridViewHeaderItem">
                                        <ContentPresenter Content="{TemplateBinding Content}"
                                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                                          Margin="0,16,0,8"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="models:ScreenshotGroup">
                            <TextBlock Text="{x:Bind DateKey}" 
                                       FontSize="20" 
                                       FontWeight="SemiBold"/>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </GridView.GroupStyle>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ScreenshotItem">
                    <Grid x:Name="ItemGrid" Width="160" Height="160" Margin="4"
                          PointerEntered="GridItem_PointerEntered"
                          PointerExited="GridItem_PointerExited"
                          CornerRadius="8"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ItemScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Image x:Name="GridImage" Source="{x:Bind ImageSource}" Stretch="UniformToFill" />
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <Grid x:Name="EmptyStateGrid" Grid.Row="1" Visibility="Visible" Background="Transparent">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="📁" FontSize="64" TextAlignment="Center"/>
                <TextBlock Text="暂无游戏截图" FontSize="24" FontWeight="SemiBold" TextAlignment="Center" />
                <Button Content="打开截图文件夹" Click="OpenEmptyFolder_Click" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid x:Name="DetailOverlayGrid" Grid.Row="1" Visibility="Collapsed" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="12,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CommandBar Grid.Column="0" DefaultLabelPosition="Right">
                    <CommandBar.PrimaryCommands>
                        <AppBarButton Icon="Back" Label="返回相册"  Click="CloseDetailView_Click"/>
                    </CommandBar.PrimaryCommands>
                </CommandBar>

                <CommandBar Grid.Column="1" DefaultLabelPosition="Right">
                    <CommandBar.PrimaryCommands>
                        <AppBarButton Icon="Copy" Label="复制" Click="CopyImage_Click" />
                        <AppBarButton Icon="Cut" Label="剪切" Click="CutImage_Click" />
                        <AppBarButton Icon="Delete" Label="删除" Click="DeleteImage_Click" />
                        <AppBarSeparator />
                        <AppBarButton Icon="Folder" Label="访问图片文件夹" Click="OpenFolder_Click" />
                        <AppBarButton Icon="OpenFile" Label="使用系统应用打开" Click="OpenWithSystemApp_Click" />
                    </CommandBar.PrimaryCommands>
                </CommandBar>
            </Grid>

            <FlipView Grid.Row="1"
                      Margin="12"
                      x:Name="DetailImageViewer"
                      Background="Transparent"
                      SelectionChanged="DetailImageViewer_SelectionChanged">
                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="models:ScreenshotItem">
                        <ScrollViewer x:Name="DetailScrollViewer"
                                      ZoomMode="Enabled"
                                      MinZoomFactor="0.1"
                                      MaxZoomFactor="10.0"
                                      HorizontalScrollMode="Auto"
                                      VerticalScrollMode="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <!--不再处理滚轮事件，因为ScrollViewer默认支持CTRL+滚轮缩放，且与FlipView切换上下项目冲突-->
                            <!--PointerWheelChanged="DetailScrollViewer_PointerWheelChanged"-->
                            <Grid Width="{Binding ElementName=DetailScrollViewer, Path=ViewportWidth}"
                                  Height="{Binding ElementName=DetailScrollViewer, Path=ViewportHeight}">
                                <Image x:Name="DetailImage"
                                       Source="{x:Bind ImageSource}"
                                       Stretch="Uniform" />
                            </Grid>
                        </ScrollViewer>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>

        </Grid>
    </Grid>
</Window>