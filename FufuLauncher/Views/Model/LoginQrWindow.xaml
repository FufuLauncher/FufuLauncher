<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FufuLauncher.Views.LoginQrWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="扫码登录">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <Storyboard x:Name="QrCodeFadeInStoryboard">
                <DoubleAnimation Storyboard.TargetName="QrCodeImage"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0" Duration="0:0:0.5" />
            </Storyboard>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" x:FieldModifier="public" Grid.Row="0" Background="Transparent">
            <TextBlock Text="扫码登录" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="14" Opacity="0.8"/>
        </Grid>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
            <ComboBox x:Name="LoginMethodComboBox" SelectedIndex="0" HorizontalAlignment="Center" SelectionChanged="LoginMethodComboBox_SelectionChanged">
                <ComboBoxItem Content="米游社APP扫码登录"/>
                <ComboBoxItem Content="通过游戏二维码登录"/>
            </ComboBox>

            <ComboBox x:Name="GameSelectionComboBox" SelectedIndex="0" HorizontalAlignment="Center" Visibility="Collapsed" SelectionChanged="GameSelectionComboBox_SelectionChanged">
                <ComboBoxItem Content="崩坏学园2" Tag="7"/>
                <ComboBoxItem Content="未定事件簿" Tag="2"/>
            </ComboBox>

            <Border Width="220" Height="220" Background="White" CornerRadius="8" Padding="10" HorizontalAlignment="Center">
                <Image x:Name="QrCodeImage" Stretch="Uniform" Opacity="0"/>
            </Border>

            <Button x:Name="RefreshButton" Content="刷新二维码" Click="RefreshButton_Click" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>