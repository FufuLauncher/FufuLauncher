<Page
    x:Class="FufuLauncher.Views.AdvancedServerSwitchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Padding="32,48,32,32">
        <StackPanel VerticalAlignment="Center" Spacing="24">
            <TextBlock Text="国际服/国服的转换" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="通过下载差分包进行转换，过程自动" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
            <Button x:Name="StartBtn" Content="一键转换" Width="200" Height="40" HorizontalAlignment="Center" Click="StartBtn_Click"/>
        </StackPanel>
    </Grid>
</Page>